1661. Average Time of Process per Machine

create database leetcode;
use leetcode;

create table if not exists activity(
machine_id int,
process_id int, 
activity_type enum("start","end"), 
timestamps float
);   

insert into activity(machine_id, process_id, activity_type, timestamps)
values
(0,0,"start",0.712),     
(0,0,"end",1.520 ),
(0,1,"start",3.140),  
(0,1,"end",4.120);
 
 select a1.machine_id, round(avg(a2.timestamps - a1.timestamps),3)
 from activity a1
 join activity a2
 on a1.machine_id = a2.machine_id
 and a1.process_id = a2.process_id
 and a1.activity_type = "start"
 and a2.activity_type = "end"
 group by a1.machine_id;
